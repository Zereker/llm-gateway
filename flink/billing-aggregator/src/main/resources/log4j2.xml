<?xml version="1.0" encoding="UTF-8"?>
<!--
  log4j2 config for billing-aggregator.

  Three loggers of note:
    - root            : human ops logs (stdout)
    - billing.batches : JSON-per-line, output via LogSink (rolling file + stdout)
    - billing.dlq     : JSON-per-line, output via DlqSink (independent rolling file + stdout)

  Production should route the batches / dlq rolling files via fluent-bit / vector
  to object storage (S3 / OSS) or a downstream Kafka topic.
-->
<Configuration status="WARN">
    <Properties>
        <Property name="batchesPath">/var/log/billing-aggregator/batches.jsonl</Property>
        <Property name="dlqPath">/var/log/billing-aggregator/dlq.jsonl</Property>
    </Properties>

    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{ISO8601} %-5level %logger{36} - %msg%n"/>
        </Console>

        <RollingFile name="Batches" fileName="${batchesPath}"
                     filePattern="${batchesPath}.%d{yyyyMMdd}.%i.gz">
            <PatternLayout pattern="%msg%n"/>
            <Policies>
                <SizeBasedTriggeringPolicy size="100 MB"/>
                <TimeBasedTriggeringPolicy/>
            </Policies>
            <DefaultRolloverStrategy max="50"/>
        </RollingFile>

        <RollingFile name="Dlq" fileName="${dlqPath}"
                     filePattern="${dlqPath}.%d{yyyyMMdd}.%i.gz">
            <PatternLayout pattern="%msg%n"/>
            <Policies>
                <SizeBasedTriggeringPolicy size="100 MB"/>
                <TimeBasedTriggeringPolicy/>
            </Policies>
            <DefaultRolloverStrategy max="50"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Logger name="billing.batches" level="INFO" additivity="false">
            <AppenderRef ref="Batches"/>
            <AppenderRef ref="Console"/>
        </Logger>

        <Logger name="billing.dlq" level="WARN" additivity="false">
            <AppenderRef ref="Dlq"/>
            <AppenderRef ref="Console"/>
        </Logger>

        <Root level="INFO">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>
