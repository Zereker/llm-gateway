# admin-apikeys.http —— APIKey CRUD（控制平面）。
#
# 路由：/admin/v1/apikeys*
# DB 不存明文：服务端生成 sk-XXX → SHA-256 hash 入库。
# **明文只在 POST 响应里返一次**，后续 GET 只见 prefix（"sk-abc1de2f..."）。

### List（?sub_account_id=&enabled= 可过滤）
GET {{admin_url}}/admin/v1/apikeys?account_id={{account_id}}
X-Admin-Token: {{admin_token}}

### List by user
GET {{admin_url}}/admin/v1/apikeys?account_id={{account_id}}&sub_account_id=alice
X-Admin-Token: {{admin_token}}

### List enabled only
GET {{admin_url}}/admin/v1/apikeys?account_id={{account_id}}&enabled=true
X-Admin-Token: {{admin_token}}

### Create（响应里 api_key 是明文 sk-...，prefix 是 sk-前 9 hex）
POST {{admin_url}}/admin/v1/apikeys
X-Admin-Token: {{admin_token}}
Content-Type: application/json

{
  "account_id": "{{account_id}}",
  "sub_account_id": "alice",
  "name": "prod",
  "group": "default",
  "external_user": false,
  "quota_policy_id": null
}

> {%
client.global.set("apikey", response.body.api_key);
client.global.set("api_key_id", response.body.api_key_id);
client.log("plaintext APIKEY (only this time): " + response.body.api_key);
%}

### Create with expiration (24h from now)
POST {{admin_url}}/admin/v1/apikeys
X-Admin-Token: {{admin_token}}
Content-Type: application/json

{
  "sub_account_id": "bob",
  "name": "ci-bot",
  "expires_at": "2026-12-31T23:59:59Z"
}

### Get by api_key_id（不返明文，只返 prefix）
GET {{admin_url}}/admin/v1/apikeys/{{api_key_id}}?account_id={{account_id}}
X-Admin-Token: {{admin_token}}

### Update: disable
PUT {{admin_url}}/admin/v1/apikeys/{{api_key_id}}?account_id={{account_id}}
X-Admin-Token: {{admin_token}}
Content-Type: application/json

{
  "enabled": false
}

### Update: 改 name + clear expires_at
PUT {{admin_url}}/admin/v1/apikeys/{{api_key_id}}?account_id={{account_id}}
X-Admin-Token: {{admin_token}}
Content-Type: application/json

{
  "name": "prod-renamed",
  "clear_expires_at": true
}

### Update: 挂 apikey 维度限流 policy（与 account.quota_policy 叠加）
PUT {{admin_url}}/admin/v1/apikeys/{{api_key_id}}?account_id={{account_id}}
X-Admin-Token: {{admin_token}}
Content-Type: application/json

{
  "quota_policy_id": 1
}

### Update: 取消 apikey 维度限流（key 维度变成不限；只受 account 维度约束）
PUT {{admin_url}}/admin/v1/apikeys/{{api_key_id}}?account_id={{account_id}}
X-Admin-Token: {{admin_token}}
Content-Type: application/json

{
  "clear_quota_policy": true
}

### Revoke (set revoked_at; gateway 立即拒绝)
POST {{admin_url}}/admin/v1/apikeys/{{api_key_id}}/revoke?account_id={{account_id}}
X-Admin-Token: {{admin_token}}

### Verify revoke 生效（gateway 该 key 应 401）
POST {{gateway_url}}/v1/chat/completions
Authorization: Bearer {{apikey}}
Content-Type: application/json

{
  "model": "{{model}}",
  "messages": [{"role": "user", "content": "should be rejected"}]
}

### Delete (软删 set deleted_at)
DELETE {{admin_url}}/admin/v1/apikeys/{{api_key_id}}?account_id={{account_id}}
X-Admin-Token: {{admin_token}}
