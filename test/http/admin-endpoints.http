# admin-endpoints.http —— Endpoint CRUD（全局上游池）。
#
# 路由：/admin/v1/endpoints*
# **v0.3 改动**：删 tenant_id（平台运营者统一管理上游；BYOK 等真要做时加 nullable tenant_id）。
# id 是 BIGINT autoinc；URL 路径用数字 id；?name= 走名字检索。
#
# auth 字段是 vendor-tagged sum type：
#   {type: "bearer",     payload: {api_key: "..."}}                 OpenAI/DeepSeek/ARK/Qwen
#   {type: "x-api-key",  payload: {api_key: "..."}}                 Anthropic
#   {type: "gemini-key", payload: {api_key: "..."}}                 Gemini AI Studio
#   {type: "aws-sigv4",  payload: {access_key, secret_key, region}} Bedrock
#   {type: "oauth2-sa",  payload: {service_account_json}}           Vertex AI
#
# 整 auth 列 AES-GCM 加密；GET 响应里 payload 字段被 mask 成 "***"。

### List all
GET {{admin_url}}/admin/v1/endpoints
X-Admin-Token: {{admin_token}}

### List by name
GET {{admin_url}}/admin/v1/endpoints?name=ark_deepseek
X-Admin-Token: {{admin_token}}

### Create: ARK / DeepSeek (bearer auth, OpenAI-compatible)
POST {{admin_url}}/admin/v1/endpoints
X-Admin-Token: {{admin_token}}
Content-Type: application/json

{
  "name": "ark_deepseek",
  "vendor": "ark",
  "model": "{{model}}",
  "group": "default",
  "weight": 100,
  "auth": {
    "type": "bearer",
    "payload": {
      "api_key": "{{ark_apikey}}"
    }
  },
  "routing": {
    "url": "{{ark_url}}"
  },
  "quota": {
    "rpm": 600,
    "tpm": 100000
  }
}

> {% client.global.set("endpoint_id", response.body.id); %}

### Create: Gemini AI Studio (gemini-key, public API key)
# 适合：免费档 / dev 试水。无需 GCP 项目。
# 客户端按 OpenAI 格式发；openai_gemini Translator 翻译。
POST {{admin_url}}/admin/v1/endpoints
X-Admin-Token: {{admin_token}}
Content-Type: application/json

{
  "name": "gemini_aistudio",
  "vendor": "gemini",
  "model": "gemini-flash-latest",
  "group": "default",
  "weight": 100,
  "auth": {
    "type": "gemini-key",
    "payload": {
      "api_key": "{{gemini_aistudio_apikey}}"
    }
  },
  "routing": {
    "url": "{{gemini_aistudio_url}}"
  }
}

### Create: Vertex AI Gemini (vertex-adc, ambient OAuth)
# 适合：生产 / GCP workload identity / 本地 `gcloud auth application-default login`。
# **gateway 进程**机器需要能读 ADC（环境 GOOGLE_APPLICATION_CREDENTIALS 或默认位置）。
# auth.payload 留空 = 用 default cloud-platform scope。
POST {{admin_url}}/admin/v1/endpoints
X-Admin-Token: {{admin_token}}
Content-Type: application/json

{
  "name": "gemini_vertex",
  "vendor": "gemini",
  "model": "gemini-1.5-flash",
  "group": "default",
  "weight": 100,
  "auth": {
    "type": "vertex-adc",
    "payload": {}
  },
  "routing": {
    "url": "{{gemini_vertex_url}}"
  }
}

### Create: Vertex AI Gemini (oauth2-sa, embedded service account JSON)
# 适合：admin 中心管理多 GCP 账号 / 不依赖 gateway 进程的 ambient ADC。
# service_account_json 整段 SA JSON 字符串嵌入 payload；admin 整段 AES-GCM 加密。
POST {{admin_url}}/admin/v1/endpoints
X-Admin-Token: {{admin_token}}
Content-Type: application/json

{
  "name": "gemini_vertex_sa",
  "vendor": "gemini",
  "model": "gemini-1.5-flash",
  "group": "default",
  "weight": 100,
  "auth": {
    "type": "oauth2-sa",
    "payload": {
      "service_account_json": "{\"type\":\"service_account\",\"project_id\":\"...\",\"private_key\":\"...\"}"
    }
  },
  "routing": {
    "url": "{{gemini_vertex_url}}"
  }
}

### Create: Anthropic example (x-api-key, 需要 anthropic adapter 才能真转发)
POST {{admin_url}}/admin/v1/endpoints
X-Admin-Token: {{admin_token}}
Content-Type: application/json

{
  "name": "anthropic_sonnet",
  "vendor": "anthropic",
  "model": "claude-3-5-sonnet-20241022",
  "group": "default",
  "weight": 100,
  "auth": {
    "type": "x-api-key",
    "payload": {
      "api_key": "sk-ant-replace-me"
    }
  },
  "routing": {
    "url": "https://api.anthropic.com/v1/messages"
  }
}

### Create: Bedrock example (AWS SigV4, region routing)
POST {{admin_url}}/admin/v1/endpoints
X-Admin-Token: {{admin_token}}
Content-Type: application/json

{
  "name": "bedrock_claude",
  "vendor": "bedrock",
  "model": "anthropic.claude-3-sonnet-20240229-v1:0",
  "group": "default",
  "weight": 100,
  "auth": {
    "type": "aws-sigv4",
    "payload": {
      "access_key": "AKIAREPLACEME",
      "secret_key": "secretreplaceme",
      "region": "us-west-2"
    }
  },
  "routing": {
    "region": "us-west-2"
  }
}

### Get by id（auth.payload 应该被 mask 成 "***"）
GET {{admin_url}}/admin/v1/endpoints/{{endpoint_id}}
X-Admin-Token: {{admin_token}}

### Update（rotate API key + adjust weight）
PUT {{admin_url}}/admin/v1/endpoints/{{endpoint_id}}
X-Admin-Token: {{admin_token}}
Content-Type: application/json

{
  "name": "ark_deepseek",
  "vendor": "ark",
  "model": "{{model}}",
  "group": "default",
  "weight": 200,
  "enabled": true,
  "auth": {
    "type": "bearer",
    "payload": {
      "api_key": "{{ark_apikey}}"
    }
  },
  "routing": {
    "url": "{{ark_url}}"
  }
}

### Delete (软删)
DELETE {{admin_url}}/admin/v1/endpoints/{{endpoint_id}}
X-Admin-Token: {{admin_token}}

# =====================================================================
# Endpoint quota → 503 验证（M7 LimitReadFilter）
#
# 跟用户限流（M6 → 429）区别：endpoint 全满是"容量问题"不是"用户违规"，所以 503。
# 实际场景：上游 vendor 给的硬上限（如 OpenAI tier1 gpt-4o 30 RPM）。
# =====================================================================

### Recreate endpoint with quota (RPM=2)
POST {{admin_url}}/admin/v1/endpoints
X-Admin-Token: {{admin_token}}
Content-Type: application/json

{
  "name": "ark_throttled",
  "vendor": "ark",
  "model": "{{model}}",
  "group": "default",
  "weight": 100,
  "auth": {
    "type": "bearer",
    "payload": {"api_key": "{{ark_apikey}}"}
  },
  "routing": {"url": "{{ark_url}}"},
  "quota": {"rpm": 2}
}

### Chat #1, #2 should 200; #3 should 503 with "all endpoints over quota"
POST {{gateway_url}}/v1/chat/completions
Authorization: Bearer {{apikey}}
Content-Type: application/json

{"model":"{{model}}","stream":false,"messages":[{"role":"user","content":"1"}]}

###
POST {{gateway_url}}/v1/chat/completions
Authorization: Bearer {{apikey}}
Content-Type: application/json

{"model":"{{model}}","stream":false,"messages":[{"role":"user","content":"2"}]}

###
POST {{gateway_url}}/v1/chat/completions
Authorization: Bearer {{apikey}}
Content-Type: application/json

{"model":"{{model}}","stream":false,"messages":[{"role":"user","content":"3"}]}

> {%
client.test("503 endpoint exhausted", () => client.assert(response.status === 503));
client.test("error mentions endpoint quota", () => {
  client.assert(response.body.error.message.indexOf("over quota") !== -1
             || response.body.error.message.indexOf("rl:endpoint") !== -1);
});
%}
